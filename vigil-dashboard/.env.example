# VIGIL Dashboard — Environment Variables
# Copy this file to .env.local for local development.
# In Vercel: add these under Project → Settings → Environment Variables.

# URL of your live backend stream endpoint.
# Must be accessible from the browser (CORS enabled, HTTPS in production).
# For ngrok: add ?ngrok-skip-browser-warning=true to avoid MIME type errors.
VITE_STREAM_URL=https://YOUR_NGROK_OR_BACKEND_URL/stream?ngrok-skip-browser-warning=true

# Base URL of your AI agent API (no trailing slash).
# The dashboard calls POST /agent/analyze on this host.
VITE_AGENT_API_URL=http://localhost:8000
